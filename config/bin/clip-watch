#!/bin/bash
# Check if another process is already running
procs=$(ps ax | grep clip-watch | grep bash | cut -d' ' -f1)

# Note: this is an odd comparison. It seems that since we background
# runs of this script, both the parent and child show up here momentarily.
# Therefore, "too long" is more than 2 pids on this line.
if [[ ${#procs} -gt 16 ]]; then  # multiple processes
    echo "Another clip-watch process is already running."
    exit 1
fi

# Run the watcher in the background
while true; do
    buffer=$(wl-paste)
    if [[ "$buffer" != "" ]]; then
        echo "$buffer" | clip add >/dev/null 2>&1 
    fi
    sleep 10
done

