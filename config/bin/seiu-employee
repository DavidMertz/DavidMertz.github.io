#!/usr/bin/env -S uvx --with polars --with tabulate python@3.15
"""
Reports obtained from:

  https://olmsapps.dol.gov/query/getOrgQryResult.do

Encoded files with e.g.:

    pprint(a85encode(lzma.compress(Path("LM2-all.csv").read_bytes())))
"""

from base64 import a85decode
import io
from os.path import basename
import sys
from zipfile import lzma  # type: ignore[import]

import polars as pl


def uncompress_to_io(enc):
    return io.BytesIO(lzma.decompress(a85decode(enc)))


def show():
    if len(sys.argv) < 1:
        print(f"USAGE {basename(__file__)} <name>")
        sys.exit()

    names = [n.upper() for n in sys.argv[1:]]
    result = (
        pl.read_csv(eval(f"LM2_all"))
        .filter(pl.col("FIRST_NAME").is_in(names) | pl.col("LAST_NAME").is_in(names))
        .select(
            [
                pl.col("LAST_NAME").alias("Last Name"),
                pl.col("FIRST_NAME").alias("First Name"),
                pl.col("YEAR").cast(pl.String).alias("Year"),
                pl.col("TITLE").alias("Title"),
                pl.col("GROSS_SALARY").alias("Salary"),
            ]
        )
        .sort(["Last Name", "Year"])
    )
    with pl.Config(
        thousands_separator=True,
        tbl_cell_numeric_alignment="RIGHT",
        tbl_hide_column_data_types=True,
        tbl_hide_dataframe_shape=True,
        tbl_formatting="UTF8_FULL_CONDENSED",
        tbl_rows=1000,
    ):
        print(result, end="\n\n")


