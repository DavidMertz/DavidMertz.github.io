#!/bin/bash
toilet='nix shell nixpkgs#toilet --command toilet'
while true; do
    clear
    date '+ %a %F %X' | $toilet -f future --gay; sleep 7
    clear
    date '+ %a %F %X' | $toilet -f future; sleep 49
    clear
    date '+ %a %F %X' | $toilet -f future --metal; sleep 11
    clear
    date '+ %a %F %X' | $toilet -f future; sleep 23
done
